views {

  view of ftrs.searchByOdsCode {
    title "FTRS Search by ODS Code Endpoint"
    description '
      APIs for search operations on the Organizations table
    '
    // include *
    include ftrs.openSearch
    include ftrs.db

    include ftrs
    include apim.dosSearchProxy
    include ftrs.db.locationTable
    exclude ftrs.gpSearchApi
    autoLayout LeftRight 70 77
  }
}
