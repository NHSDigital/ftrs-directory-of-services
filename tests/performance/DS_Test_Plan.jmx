              <hashTree />
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor"
                testname="Set Bearer Token as Property" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def bearerToken = vars.get(&quot;varBearer&quot;)
                  def iteration = vars.getIteration()

                  // Log the response for debugging
                  def responseCode = prev.getResponseCode()
                  def responseBody = prev.getResponseDataAsString()
                  log.info(&quot;Token response code: ${responseCode}&quot;)
                  log.info(&quot;Token response body: ${responseBody}&quot;)

                  if (bearerToken != null &amp;&amp; !bearerToken.isEmpty() &amp;&amp; bearerToken
                  != &quot;TOKEN_NOT_FOUND&quot;) {
                  props.put(&quot;varBearer&quot;, bearerToken)
                  log.info(&quot;Iteration ${iteration}: Bearer token successfully set&quot;)
                  } else {
                  log.error(&quot;Iteration ${iteration}: Bearer token is null!&quot;)
                  }
</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PostProcessor>
              <hashTree />
            </hashTree>
