        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler"
          testname="Set Test Mode and Operation Variables">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">// Set boolean properties based on test_mode property
            log.info(&quot;Setting test mode variables for CRUD test plan&quot;)
            def testMode = props.get(&quot;test_mode&quot;)
            props.put(&quot;isProxyMode&quot;, (testMode == &quot;proxy&quot;).toString())
            props.put(&quot;isLoadMode&quot;, (testMode == &quot;load&quot;).toString())
            props.put(&quot;isStressMode&quot;, (testMode == &quot;stress&quot;).toString())

            // Set test operation variables (get or put)
            def testOperation = props.get(&quot;test_operation&quot;) ?: &quot;get&quot;
            props.put(&quot;isGetOp&quot;, (testOperation == &quot;get&quot;).toString())
            props.put(&quot;isPutOp&quot;, (testOperation == &quot;put&quot;).toString())
            log.info(&quot;Test mode and operation variables set successfully&quot;)

            def scriptFile = new File(&apos;./scripts/LoadParams.groovy&apos;)
            def scriptText = scriptFile.text
            evaluate(scriptText)

            log.info(&quot;Configuration loaded successfully&quot;) </stringProp>
        </JSR223Sampler>
