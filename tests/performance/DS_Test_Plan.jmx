          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor"
              testname="AWS Secrets Manager - JSR223 PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="script">import com.amazonaws.auth.DefaultAWSCredentialsProviderChain
                import com.amazonaws.services.secretsmanager.AWSSecretsManagerClientBuilder
                import com.amazonaws.services.secretsmanager.model.GetSecretValueRequest
                import com.amazonaws.services.secretsmanager.model.GetSecretValueResult
                import groovy.json.JsonSlurper

                try {
                String secretName = props.get(&quot;AWS_SECRET_NAME&quot;) ?:
                vars.get(&quot;AWS_SECRET_NAME&quot;)
                String region = props.get(&quot;AWS_REGION&quot;) ?:
                vars.get(&quot;AWS_REGION&quot;) ?: &quot;eu-west-2&quot;

                log.info(&quot;Fetching secret: ${secretName} from region: ${region}&quot;)

                def client = AWSSecretsManagerClientBuilder.standard()
                .withRegion(region)
                .withCredentials(new DefaultAWSCredentialsProviderChain())
                .build()

                GetSecretValueRequest getSecretValueRequest = new GetSecretValueRequest()
                .withSecretId(secretName)

                GetSecretValueResult getSecretValueResult =
                client.getSecretValue(getSecretValueRequest)
                String secretString = getSecretValueResult.getSecretString()
                log.info(&quot;Successfully retrieved secret&quot;)

                def jsonSlurper = new JsonSlurper()
                def secretJson = jsonSlurper.parseText(secretString)

                secretJson.each { key, value -&gt;
                vars.put(key as String, value as String)
                log.info(&quot;Set variable: ${key}&quot;)
                }

                log.info(&quot;Successfully processed secret key-value pairs&quot;)

                } catch (ClassNotFoundException e) {
                log.error(&quot;AWS SDK classes not found&quot;)
                log.error(&quot;Error: ${e.message}&quot;, e)
                } catch (Exception e) {
                log.error(&quot;Error fetching or processing AWS secret: ${e.message}&quot;, e)
                e.printStackTrace()
                }
</stringProp>
            </JSR223PreProcessor>
            <hashTree />
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate JWT Token - JSR223 PreProcessor" enabled="true">
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import com.auth0.jwt.JWT
import com.auth0.jwt.algorithms.Algorithm

import java.security.KeyFactory
import java.security.interfaces.RSAPrivateKey
import java.security.spec.PKCS8EncodedKeySpec
import java.util.Base64
import java.util.Date
import java.util.Map
import java.util.UUID

    String apiKey = vars.get(&quot;api_key&quot;)
    String kidName = vars.get(&quot;kid&quot;)
    String key = vars.get(&quot;private_key&quot;)
    long tokenExpireTime = 300000

    // Strip PEM headers/footers and whitespace to get raw base64
    String[] parts = key.split(&quot;-----&quot;)
    String cert = parts[2]
    String privateKeyPem = cert.replaceAll(&quot;\\s&quot;, &quot;&quot;)

    // Load PKCS#8 private key
    byte[] keyBytes = Base64.getDecoder().decode(privateKeyPem)
    PKCS8EncodedKeySpec spec = new PKCS8EncodedKeySpec(keyBytes)
    KeyFactory kf = KeyFactory.getInstance(&quot;RSA&quot;)
    RSAPrivateKey privateKey = (RSAPrivateKey) kf.generatePrivate(spec)

    String tokenUrl = vars.get(&quot;token_url&quot;)
    String jwtId = UUID.randomUUID().toString()
    long nowMillis = System.currentTimeMillis()
    long expMillis = nowMillis + tokenExpireTime

    Algorithm algorithm = Algorithm.RSA512(null, privateKey)

    String jwtToken = JWT.create()
            .withSubject(apiKey)
            .withIssuer(apiKey)
            .withAudience(tokenUrl)
            .withJWTId(jwtId)
            .withExpiresAt(new Date(expMillis))
            .withHeader(Map.of(&quot;kid&quot;, kidName))
            .sign(algorithm)

    vars.put(&quot;JWT_Token&quot;, jwtToken)
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
