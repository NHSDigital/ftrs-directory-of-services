{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AWSBackupReadOnlyAccess",
            "Effect": "Allow",
            "Action": [
                "backup:Describe*",
                "backup:Get*",
                "backup:List*"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AWSFaultInjectionSimulatorReadOnlyAccess",
            "Effect": "Allow",
            "Action": [
                "fis:Get*",
                "fis:List*"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AWSResilienceHubReadOnlyAccess",
            "Effect": "Allow",
            "Action": [
                "resiliencehub:Describe*",
                "resiliencehub:Get*",
                "resiliencehub:List*"
            ],
            "Resource": "*"
        }
    ]
}